# OLX CLI - Environment Variables
#
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Backend de Scraping ────────────────────────────────────────────────
# Escolha qual motor de scraping usar para acessar a OLX.
# Valores: crawl4ai (default) | firecrawl
# OLX_BACKEND=crawl4ai

# ── Crawl4AI (default) ─────────────────────────────────────────────────
# URL base do servidor Crawl4AI rodando via Docker/Coolify.
# Descomente e ajuste para seu ambiente:
# OLX_BASE_URL=https://seu-crawl4ai:8000
# OLX_BASE_URL=https://crawl4ai:8000           # Docker internal
# OLX_BASE_URL=https://b279i8mvg0nr9p9cjp1exd1d.152.67.46.88.sslip.io  # Exemplo real

# ── Firecrawl ──────────────────────────────────────────────────────────
# URL base do servidor Firecrawl.
# Descomente e ajuste para usar Firecrawl como backend:
# OLX_BACKEND=firecrawl
# OLX_BASE_URL=http://localhost:3002             # Docker local
# OLX_BASE_URL=https://seu-firecrawl.railway.app # Railway / Coolify

# ── Alternativa (fallback para base URL) ───────────────────────────────
# CRAWL4AI_URL também funciona como fallback para definir a base URL
# quando OLX_BASE_URL não está definida.
# CRAWL4AI_URL=https://crawl4ai:8000
