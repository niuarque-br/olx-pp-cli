# OLX CLI - Environment Variables
#
# Copy this file to .env and fill in the values.
# cp .env.example .env

# URL base do Crawl4AI (backend de scraping)
# O CLI usa esta URL para fazer as requisições à OLX via browser headless
OLX_BASE_URL=https://crawl4ai:8000

# Backend de scraping
# Valores: crawl4ai (default) | firecrawl
# OLX_BACKEND=crawl4ai

# Alternativa: CRAWL4AI_URL também funciona como fallback para base URL
# CRAWL4AI_URL=https://crawl4ai:8000
