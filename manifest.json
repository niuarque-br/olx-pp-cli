{
  "manifest_version": "0.3",
  "name": "olx-pp-mcp",
  "display_name": "Olx Brasil De",
  "version": "0.0.0",
  "description": "CLI para buscar e consultar anúncios da OLX Brasil.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/olx-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/olx-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
